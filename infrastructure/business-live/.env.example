# HMZ_BUSINESS_LIVE_HOSTING environment placeholders
#
# Copy this file to `.env` in this directory and fill in real values.
# Do NOT commit `.env`. This file contains no secrets.
#
# This file configures HOSTING ONLY (which domain n8n is reachable at, the
# n8n encryption key, timezone). It does not affect DRY_RUN, LIVE_CAMPAIGNS,
# or any of the business-ready safety gates - those remain in
# config/business-ready.config.json and the n8n environment/credentials,
# unchanged by this file.

# Public hostname this stack will be reachable at (DNS A/AAAA record must
# already point at this host's public IP before starting reverse-proxy, so
# Caddy can obtain a Let's Encrypt certificate).
N8N_HOST=<REQUIRED_PUBLIC_N8N_HOSTNAME>

# Email address used for Let's Encrypt account registration/expiry notices.
# Not exposed publicly.
ACME_EMAIL=<REQUIRED_ACME_CONTACT_EMAIL>

# n8n encryption key for credentials at rest. Generate once with:
#   openssl rand -hex 24
# Back this value up securely (e.g. password manager) - if lost, n8n cannot
# decrypt stored credentials and they must be re-entered.
N8N_ENCRYPTION_KEY=<REQUIRED_N8N_ENCRYPTION_KEY>

# Timezone for n8n scheduling / SLA Watchdog timestamps.
GENERIC_TIMEZONE=Europe/London

# Google Chat incoming webhook URL used by the Human Approval, Error
# Handler, and SLA Watchdog validation workflows (the `$env.GOOGLE_CHAT_WEBHOOK_URL`
# expressions in their "POST Google Chat Webhook" nodes - no workflow JSON
# change is required). This secret lives ONLY in this deployment's `.env`
# file (not committed) and is passed into the n8n container's environment by
# docker-compose.yml. No separate `hmzGoogleChatWebhook` n8n credential is
# required by the current implementation.
GOOGLE_CHAT_WEBHOOK_URL=<REQUIRED_GOOGLE_CHAT_WEBHOOK_URL>
N8N_BLOCK_ENV_ACCESS_IN_NODE=false
