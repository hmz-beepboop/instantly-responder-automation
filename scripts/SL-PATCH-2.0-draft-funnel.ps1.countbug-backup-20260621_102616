const AI_API_KEY = (typeof $env !== 'undefined' && $env.ANTHROPIC_API_KEY) ? $env.ANTHROPIC_API_KEY : '';

// HMZ_INJECT_BEGIN:SENDER_CONFIG
const SENDER_CONFIG = {};
