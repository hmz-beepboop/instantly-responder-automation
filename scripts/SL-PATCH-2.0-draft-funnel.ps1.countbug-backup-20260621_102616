<#
.SYNOPSIS
  SL-PATCH-2.0: Draft Funnel Upgrade вЂ” Micro Intent + AI Supervised Draft + Deterministic Fallback

.DESCRIPTION
  Adds a 7-step draft funnel to the Decision Engine:
    1. Broad category (Section A/B вЂ” unchanged)
    2. Micro intent detection (injected into Section B output)
    3. Draft policy selection (injected into Section B output)
    4. AI draft attempt (Section D, AI_DRAFT_MODE=supervised, Claude Haiku)
    5. AI output validation (inline in Section D)
    6. Deterministic fallback for all 14 micro intents (Section D)
    7. draft_source field: ai_supervised | deterministic_template | ai_failed_fallback | human_only | none

  Human approval remains mandatory. AI never decides send eligibility. Sender gates unchanged.

.PARAMETER WhatIf
  Preview all changes. No writes. No API calls except backup reads.

.PARAMETER Apply
  Execute the patch: backup в†’ deactivate в†’ patch в†’ reactivate в†’ verify.

.NOTES
  SAFE TO RE-RUN: script is idempotent (PUT replaces full workflow JSON).
  Requires env var: HMZ_N8N_API_KEY
  Requires env var: ANTHROPIC_API_KEY (for AI drafts at runtime; not required for the patch itself)
  Version: SL-PATCH-2.0
#>

param(
    [switch]$WhatIf,
    [switch]$Apply
)

Set-StrictMode -Version Latest
$ErrorActionPreference = 'Stop'

# в”Ђв”Ђв”Ђ CONSTANTS в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
$API_BASE = 'https://n8n.hmzaiautomation.com/api/v1'

$WF = [ordered]@{
    Intake        = 'VtDQqw02Ux1TgjIH'
    SLAWatchdog   = '6a8ojyXCwMwI9nyF'
    ErrorHandler  = '2PR9YEkG4KyGdowa'
    HumanApproval = '9aPrt92jFhoYFxbs'
    Decision      = 'tgYmY97CG4Bm8snI'
