Invoke-N8n -Method PUT -Path "/workflows/$($WF.Decision)" -Body $deWf | Out-Null
Write-Host "  PATCHED Decision Engine"

# в”Ђв”Ђ STEP 4: PATCH HUMAN APPROVAL в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
Write-Host "`n[4/5] Patching Human Approval ($($WF.HumanApproval))..."

$haWf   = $backups['HumanApproval'] | ConvertTo-Json -Depth 60 | ConvertFrom-Json
$haNode = Find-Node -Nodes $haWf.nodes -Name 'A. Build Review Case Record'

$existingCode = $haNode.parameters.jsCode
if ($existingCode -notmatch [regex]::Escape($HA_SPLICE_MARKER)) {
    throw "Could not find splice marker '$HA_SPLICE_MARKER' in 'A. Build Review Case Record' jsCode. Aborting."
}
if ($existingCode -match 'micro_intent:') {
    Write-Host "  INFO: micro_intent already present вЂ” Human Approval already patched. Skipping."
} else {
    $haNode.parameters.jsCode = $existingCode.Replace(
        $HA_SPLICE_MARKER,
        $HA_SPLICE_MARKER + $HA_SPLICE_INJECT
    )
    Invoke-N8n -Method PUT -Path "/workflows/$($WF.HumanApproval)" -Body $haWf | Out-Null
    Write-Host "  PATCHED Human Approval"
}

# в”Ђв”Ђ STEP 5: REACTIVATE в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
Write-Host "`n[5/5] Reactivating (safe order)..."
foreach ($name in $REACTIVATE_ORDER) {
    Set-Active -Name $name -Id $WF[$name] -Active $true
}

# в”Ђв”Ђ STEP 6: OFFLINE TESTS в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
$allPass = Run-OfflineTests

if ($allPass) {
    Write-Host "`nPATCH_APPLIED_AND_VERIFIED"
} else {
    Write-Warning "`nPATCH APPLIED BUT SOME OFFLINE TESTS FAILED вЂ” review output above before sending live traffic."
    exit 1
}
