    "../verification/patch-3.0-backup/$(Get-Date -Format 'yyyyMMddTHHmmssZ')"

# ─── HELPERS ──────────────────────────────────────────────────────────────────
function Get-ApiKey {
    $k = $env:HMZ_N8N_API_KEY
    if (-not $k) { throw 'HMZ_N8N_API_KEY env var is not set.' }
    return $k
}

function Invoke-N8n {
    # HMZ_API_SHIM_V3
    [CmdletBinding()]
    param(
        [Parameter(Position=0)][Alias('Verb')][string]$Method,
        [Parameter(Position=1)][Alias('Uri','Url','Endpoint','Route','ApiPath')][string]$Path,
        [Parameter(Position=2)][Alias('Payload','RequestBody','JsonBody','Data','Workflow')]$Body = $null,
        [Parameter(ValueFromRemainingArguments=$true)]$Rest
    )

    function _hmzGetScriptVar([string[]]$Names) {
        foreach ($n in $Names) {
            $v = Get-Variable -Scope Script -Name $n -ErrorAction SilentlyContinue
            if ($null -ne $v) { return $v.Value }
        }
        return $null
    }
    function _hmzProp($Obj, [string]$Name) {
        if ($null -eq $Obj) { return $null }
        if ($Obj -is [System.Collections.IDictionary]) { if ($Obj.Contains($Name)) { return $Obj[$Name] } return $null }
        $p = $Obj.PSObject.Properties[$Name]; if ($null -ne $p) { return $p.Value }; return $null
    }
    function _hmzHasProp($Obj, [string]$Name) {
        if ($null -eq $Obj) { return $false }
        if ($Obj -is [System.Collections.IDictionary]) { return $Obj.Contains($Name) }
        return ($null -ne $Obj.PSObject.Properties[$Name])
    }

    $validMethods = @('GET','POST','PUT','PATCH','DELETE')
    $methodText = [string]$Method; $pathText = [string]$Path; $bodyToSend = $Body

    if ($methodText -match '^(https?://|/)' -and ($validMethods -contains $pathText.ToUpperInvariant())) { $tmp=$methodText;$methodText=$pathText;$pathText=$tmp }
    elseif (-not ($validMethods -contains $methodText.ToUpperInvariant()) -and ($validMethods -contains $pathText.ToUpperInvariant())) { $tmp=$methodText;$methodText=$pathText;$pathText=$tmp }
    elseif (([string]::IsNullOrWhiteSpace($pathText)) -and ($methodText -match '^(https?://|/)')) { $pathText=$methodText;$methodText='GET' }

    if ($Rest -and $Rest.Count -gt 0 -and $null -eq $bodyToSend) { $bodyToSend = $Rest[0] }
    $methodUpper = $methodText.ToUpperInvariant()
    if (-not ($validMethods -contains $methodUpper)) { throw ("Unsupported method: '{0}'" -f $methodText) }
    if ([string]::IsNullOrWhiteSpace($pathText)) { throw ("No path for method {0}." -f $methodUpper) }

    if ($methodUpper -eq 'PATCH' -and $pathText -match '^/workflows/([^/]+)$') {
        $wfId = $Matches[1]; $activeValue = _hmzProp $bodyToSend 'active'
        if ($activeValue -eq $true)  { $methodUpper='POST'; $pathText="/workflows/$wfId/activate";   $bodyToSend=$null }
        elseif ($activeValue -eq $false) { $methodUpper='POST'; $pathText="/workflows/$wfId/deactivate"; $bodyToSend=$null }
        else { throw ("Unsupported PATCH /workflows/{0} without active=true/false." -f $wfId) }
    }

    if ($methodUpper -eq 'PUT' -and $pathText -match '^/workflows/([^/]+)$' -and $null -ne $bodyToSend) {
        $candidate = $bodyToSend
        $nwf = _hmzProp $candidate 'workflow'; if ($null -ne $nwf) { $candidate = $nwf }
        $nwf2 = _hmzProp $candidate 'wf';      if ($null -ne $nwf2){ $candidate = $nwf2 }
        if ((_hmzHasProp $candidate 'name') -and (_hmzHasProp $candidate 'nodes') -and (_hmzHasProp $candidate 'connections')) {
            $settings = _hmzProp $candidate 'settings'; if ($null -eq $settings) { $settings = @{} }
            $sanitized = [ordered]@{ name=(_hmzProp $candidate 'name'); nodes=(_hmzProp $candidate 'nodes'); connections=(_hmzProp $candidate 'connections'); settings=$settings }
            if (_hmzHasProp $candidate 'staticData') { $sd=_hmzProp $candidate 'staticData'; if($null -ne $sd){$sanitized.staticData=$sd} }
            if (_hmzHasProp $candidate 'pinData')    { $pd=_hmzProp $candidate 'pinData';    if($null -ne $pd){$sanitized.pinData=$pd} }
            $bodyToSend = $sanitized
        }
    }

    $base = _hmzGetScriptVar @('N8N_BASE','N8N_API_BASE','BASE_URL','ApiBase','BaseUrl','API_BASE')
    if (-not $base) { $base = 'https://n8n.hmzaiautomation.com/api/v1' }
    $uri = if ($pathText -match '^https?://') { $pathText } else { "$base$pathText" }

    $hdrs = _hmzGetScriptVar @('headers','Headers','HEADERS')
    if (-not $hdrs) {
        if (-not $env:HMZ_N8N_API_KEY) { throw "HMZ_N8N_API_KEY not set." }
        $hdrs = @{ 'X-N8N-API-KEY'=$env:HMZ_N8N_API_KEY; 'Accept'='application/json'; 'Content-Type'='application/json' }
    }

    $whatIfFlag = _hmzGetScriptVar @('WhatIf')
    if ([bool]$whatIfFlag -and ($methodUpper -in @('POST','PUT','PATCH','DELETE'))) {
        Write-Host ("[WHATIF] {0} {1}" -f $methodUpper, $uri); return $null
    }

    $p = @{ Uri=$uri; Headers=$hdrs; Method=$methodUpper }
    if ($null -ne $bodyToSend) { $p.Body=($bodyToSend | ConvertTo-Json -Depth 100); $p.ContentType='application/json' }
    return Invoke-RestMethod @p
}

function Backup-Wf {
    param([string]$Name, [string]$Id)
    $wf   = Invoke-N8n -Method GET -Path "/workflows/$Id"
    $path = Join-Path $BACKUP_DIR "$Name-$Id.json"
    $wf | ConvertTo-Json -Depth 60 | Set-Content -Path $path -Encoding UTF8
    Write-Host "  BACKUP  $Name → $([System.IO.Path]::GetFileName($path))"
    return $wf
}

function Set-Active {
    param([string]$Name, [string]$Id, [bool]$Active)
    $verb = if ($Active) { 'activate' } else { 'deactivate' }
    try   { Invoke-N8n -Method PATCH -Path "/workflows/$Id/$verb" | Out-Null; Write-Host "  $($verb.ToUpper().PadRight(12)) $Name ($Id)" }
    catch { Write-Warning "  $verb failed for $Name ($Id): $_" }
}

function Find-Node {
    param($Nodes, [string]$Name)
    $n = $Nodes | Where-Object { $_.name -eq $Name } | Select-Object -First 1
    if (-not $n) { throw "Node '$Name' not found in workflow." }
    return $n
}

