{
  "_comment": "Machine-readable schema for the three autonomous DataTables to be created in n8n when shadow mode is activated.",
  "_version": "1.0.0",
  "_date": "2026-06-24",
  "_status": "PROPOSAL — not yet created in production",

  "tables": [
    {
      "name": "hmz-autonomous-shadow-log",
      "description": "Shadow evaluation log for all candidates evaluated by the autonomous eligibility engine",
      "retention_days": 90,
      "primary_key": "correlation_id",
      "columns": [
        { "name": "correlation_id", "type": "string", "required": true, "description": "Unique per evaluation" },
        { "name": "case_id", "type": "string", "required": true },
        { "name": "thread_id", "type": "string", "required": true },
        { "name": "campaign_id", "type": "string", "required": true },
        { "name": "sender_email", "type": "string", "required": true },
        { "name": "recipient_email", "type": "string", "required": true },
        { "name": "incoming_text_excerpt", "type": "string", "required": true, "max_length": 200 },
        { "name": "detected_broad_category", "type": "string", "required": true },
        { "name": "detected_micro_intent", "type": "string", "required": true },
        { "name": "additional_intents", "type": "json_array", "required": true },
        { "name": "confidence", "type": "decimal", "required": true },
        { "name": "would_be_shadow_eligible", "type": "boolean", "required": true },
        { "name": "would_send_live_now", "type": "boolean", "required": true },
        { "name": "blocked_reason", "type": "string", "required": false },
        { "name": "recommended_action", "type": "string", "required": true, "enum": ["SHADOW_LOG","HUMAN_REVIEW","BLOCKED_PERMANENT","AUTONOMOUS_ELIGIBLE"] },
        { "name": "draft_that_would_have_been_sent", "type": "string", "required": false },
        { "name": "active_rules_used", "type": "json_array", "required": true },
        { "name": "risk_flags", "type": "json_array", "required": true },
        { "name": "reviewer_action_needed", "type": "boolean", "required": true },
        { "name": "follow_up_needed", "type": "boolean", "required": false, "default": false },
        { "name": "learning_signal_created", "type": "boolean", "required": true },
        { "name": "autonomous_mode_state", "type": "string", "required": true },
        { "name": "dry_run_state", "type": "boolean", "required": true },
        { "name": "shadow_only_state", "type": "boolean", "required": true },
        { "name": "timestamp", "type": "datetime", "required": true },
        { "name": "working_hours_at_evaluation", "type": "boolean", "required": true }
      ]
    },
    {
      "name": "hmz-autonomous-review-queue",
      "description": "Cases requiring owner review — high-risk blocks, autonomous sends, escalations",
      "retention_days": 365,
      "primary_key": "queue_id",
      "columns": [
        { "name": "queue_id", "type": "string", "required": true },
        { "name": "case_id", "type": "string", "required": true },
        { "name": "correlation_id", "type": "string", "required": true },
        { "name": "thread_id", "type": "string", "required": true },
        { "name": "campaign_id", "type": "string", "required": true },
        { "name": "sender_email", "type": "string", "required": true },
        { "name": "recipient_email", "type": "string", "required": true },
        { "name": "queue_reason", "type": "string", "required": true },
        { "name": "priority", "type": "string", "required": true, "enum": ["HIGH","MEDIUM","LOW"] },
        { "name": "incoming_text_excerpt", "type": "string", "required": true, "max_length": 200 },
        { "name": "recommended_action", "type": "string", "required": true },
        { "name": "was_autonomous_send", "type": "boolean", "required": true },
        { "name": "draft_sent", "type": "string", "required": false },
        { "name": "awaiting_post_action_review", "type": "boolean", "required": true },
        { "name": "created_at", "type": "datetime", "required": true },
        { "name": "reviewed_at", "type": "datetime", "required": false },
        { "name": "review_outcome", "type": "string", "required": false }
      ]
    },
    {
      "name": "hmz-autonomous-daily-digest",
      "description": "Generated daily digests for audit and trend tracking",
      "retention_days": 365,
      "primary_key": "digest_id",
      "columns": [
        { "name": "digest_id", "type": "string", "required": true },
        { "name": "digest_period_start", "type": "datetime", "required": true },
        { "name": "digest_period_end", "type": "datetime", "required": true },
        { "name": "generated_at", "type": "datetime", "required": true },
        { "name": "total_candidates", "type": "integer", "required": true },
        { "name": "shadow_eligible", "type": "integer", "required": true },
        { "name": "blocked", "type": "integer", "required": true },
        { "name": "autonomous_sends", "type": "integer", "required": true },
        { "name": "kill_switch_events", "type": "integer", "required": true },
        { "name": "digest_json", "type": "json", "required": true }
      ]
    }
  ]
}
