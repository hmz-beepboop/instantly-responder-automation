{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HMZ Autonomous Shadow Candidate Log Schema",
  "version": "1.0.0",
  "date": "2026-06-24",
  "type": "object",
  "required": ["case_id", "correlation_id", "thread_id", "campaign_id", "sender_email", "recipient_email", "incoming_text_excerpt", "detected_broad_category", "detected_micro_intent", "additional_intents", "eligibility_decision", "would_be_shadow_eligible", "would_send_live_now", "recommended_action", "active_rules_used", "confidence", "risk_flags", "reviewer_action_needed", "learning_signal_created", "autonomous_mode_state", "dry_run_state", "shadow_only_state", "timestamp", "working_hours_at_evaluation"],
  "properties": {
    "case_id":                    { "type": "string" },
    "correlation_id":             { "type": "string" },
    "thread_id":                  { "type": "string" },
    "campaign_id":                { "type": "string" },
    "sender_email":               { "type": "string" },
    "recipient_email":            { "type": "string" },
    "incoming_text_excerpt":      { "type": "string", "maxLength": 200 },
    "detected_broad_category":    { "type": "string" },
    "detected_micro_intent":      { "type": "string" },
    "additional_intents":         { "type": "array", "items": { "type": "string" } },
    "eligibility_decision":       { "type": "object" },
    "would_be_shadow_eligible":   { "type": "boolean" },
    "would_send_live_now":        { "type": "boolean" },
    "blocked_reason":             { "type": ["string", "null"] },
    "recommended_action":         { "type": "string", "enum": ["SHADOW_LOG", "HUMAN_REVIEW", "BLOCKED_PERMANENT", "AUTONOMOUS_ELIGIBLE"] },
    "draft_that_would_have_been_sent": { "type": ["string", "null"] },
    "active_rules_used":          { "type": "array", "items": { "type": "string" } },
    "confidence":                 { "type": "number", "minimum": 0, "maximum": 1 },
    "risk_flags":                 { "type": "array", "items": { "type": "string" } },
    "reviewer_action_needed":     { "type": "boolean" },
    "follow_up_needed":           { "type": "boolean", "default": false },
    "learning_signal_created":    { "type": "boolean" },
    "autonomous_mode_state":      { "type": "string", "enum": ["SHADOW_ONLY", "DRY_RUN", "DISABLED", "CONTROLLED_PILOT", "LIVE"] },
    "dry_run_state":              { "type": "boolean" },
    "shadow_only_state":          { "type": "boolean" },
    "timestamp":                  { "type": "string", "format": "date-time" },
    "working_hours_at_evaluation": { "type": "boolean" }
  }
}
