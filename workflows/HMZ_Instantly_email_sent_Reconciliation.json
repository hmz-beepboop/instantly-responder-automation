        880,
        -80
      ]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ status: $json.response_message }) }}",
        "options": {
          "responseCode": "={{ $json.response_code }}"
        }
      },
      "name": "Respond Ignored",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.2,
      "position": [
        660,
        120
      ]
    },
    {
      "parameters": {
        "content": "## HMZ — Instantly email_sent Reconciliation\nNotification-only. NO send, NO Google Chat post. Forwards email_sent to the reply-console sidecar which reconciles ONLY open RECONCILING supervised-send attempts (thread+account+recipient+subject+body-hash+timestamp). Unrelated campaign email_sent events are ignored cheaply.",
        "height": 200,
        "width": 420
      },
      "name": "About",
