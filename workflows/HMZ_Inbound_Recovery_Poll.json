{
  "name": "HMZ — Inbound Recovery Poll",
  "settings": {
    "executionOrder": "v1"
  },
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "minutes",
              "minutesInterval": 1
            }
          ]
        }
      },
      "name": "Every minute",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        0,
        0
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://hmz-reply-console:5691/v2/poll",
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "json",
        "jsonBody": "={{ '{}' }}",
        "options": {
          "timeout": 25000,
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "name": "Poll Recover (sidecar)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        240,
        0
      ],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "content": "## HMZ — Inbound Recovery Poll v2\nEvery minute, scans the complete recent Instantly received-email range with overlap and ID deduplication. Every returned record is atomically registered with an outbox before cursor commit; categories and malformed metadata cannot suppress notification. Cursor commits only after full pagination and durable representation. No prospect sends.",
        "height": 180,
        "width": 420
      },
      "name": "About",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        0,
        140
      ]
    }
  ],
  "connections": {
    "Every minute": {
      "main": [
        [
          {
            "node": "Poll Recover (sidecar)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
