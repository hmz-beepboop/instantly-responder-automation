# Instantly Responder Automation — environment variable placeholders
#
# Copy this file to `.env` and fill in local values. Do NOT commit `.env`.
# No real values, addresses, or secrets are present in this file.
#
# This file distinguishes:
#  - REFERENCE VALUES: verified, non-secret constants that do not change
#    per environment (e.g. the Instantly API host).
#  - RUNTIME CONFIGURATION: environment-specific values an operator sets
#    (n8n URL/API key, sidecar URL, operating-mode/safety gates).
# Non-secret runtime configuration that is shared across scripts and
# workflows (campaign allowlist, sender mapping, SLOs, retention, etc.) lives
# in `config/business-ready.config.json`, not here. Secrets stay only in
# n8n credentials/environment, never in workflow JSON, config JSON, or logs.

# --- Local n8n (runtime configuration) ---
# Local n8n base URL (bound to 127.0.0.1 only; see docker-compose.yml).
N8N_BASE_URL=http://localhost:5678

# n8n REST API base used by verification/business-ready scripts
# (e.g. http://127.0.0.1:5678/api/v1). Used only for offline/audit tooling
# and the apply/acceptance scripts. Never used to make a live Instantly call.
N8N_API_URL=http://127.0.0.1:5678/api/v1

# n8n API key used by verification/business-ready scripts (apply, runtime
# acceptance, rollback). Never commit a real key. Leave blank until generated
# locally via the n8n owner account. Stored only as an environment variable /
# n8n credential, never in workflow JSON.
HMZ_N8N_API_KEY=<local-n8n-api-key-placeholder>

# --- Operating mode / safety gates (runtime configuration) ---
# Must remain VALIDATION until all business-ready follow-up gates are met.
OPERATING_MODE=VALIDATION

# Global send guard. Must remain true until explicit owner approval, the
# full pre-send gate (docs/HMZ_APPROVED_REPLY_RULES.md §9.1), and actual
# n8n-runtime evidence for the Sender/Error Handler workflows exist.
DRY_RUN=true

# Exact Instantly campaign IDs allowed to send. Empty = nothing sends.
# Example placeholder format (do not populate with real IDs yet):
# LIVE_CAMPAIGNS=["<exact-campaign-id-placeholder>"]
LIVE_CAMPAIGNS=[]

# --- Instantly API (reference value; unused while DRY_RUN=true) ---
# Bearer token for Instantly API v2. Clearly UNUSED while DRY_RUN=true and
# LIVE_CAMPAIGNS=[]. Store only in n8n credentials/environment, never in
# workflow JSON or logs. Bound to the n8n credential named "hmzInstantlyApi"
# (config/business-ready.config.json instantly_api.reply_credential_name),
# referenced by the gated/unreachable live-send and suppression adapter
# nodes added by verification/business-ready/build-live-path.mjs. Until
# config.live_credential_readiness.instantly is true, those nodes are never
# reached regardless of whether this credential is bound.
INSTANTLY_API_KEY=<instantly-api-key-placeholder-unused-until-approved>

# Verified Instantly V2 API host (reference value; reports/INSTANTLY_VERIFICATION_EVIDENCE.md).
INSTANTLY_API_BASE=https://api.instantly.ai

# --- hmz-send-state sidecar (runtime configuration) ---
# Internal-only URL on the Docker Compose network (no published host port).
HMZ_SEND_STATE_URL=http://hmz-send-state:5681

# Sidecar durable-state directory inside its container (named Docker volume).
HMZ_SEND_STATE_DIR=/data

# --- Human Approval review surface (runtime configuration; business-ready) ---
# Public HTTPS base URL for the reviewer-facing approval form. Required
# before review_destination_status can move from NOT_CONFIGURED.
REVIEW_BASE_URL=<https-review-base-url-placeholder>

# Google Chat incoming webhook URL. Secret — store ONLY as the n8n credential
# named in config/business-ready.config.json
# (review.google_chat_credential_name = "hmzGoogleChatWebhook"). Never place
# the real URL in this file, workflow JSON, or any report.
GOOGLE_CHAT_WEBHOOK_URL=<google-chat-incoming-webhook-url-placeholder>

# Shared-secret token for the production Instantly reply webhook path
# (config/business-ready.config.json webhook_protection). Store only as the
# n8n credential named "hmzInstantlyWebhookToken". The production webhook
# path is fixed at "instantly-reply"
# (workflows/01_reply_intake_validation.json, "Webhook - Instantly Reply
# Intake (Production, Gated)"), separate from the dev/synthetic path above.
HMZ_INSTANTLY_WEBHOOK_TOKEN=<instantly-webhook-shared-secret-placeholder>
